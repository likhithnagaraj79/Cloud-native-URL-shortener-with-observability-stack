{
  "title": "URL Shortener",
  "uid": "url-shortener",
  "version": 1,
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "URLs Created (total)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "url_shortener_urls_created_total", "legendFormat": "Total"}],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Redirects per Second",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "rate(url_shortener_redirects_total[1m])", "legendFormat": "{{short_code}}"}],
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "rate(url_shortener_cache_hits_total[5m]) / (rate(url_shortener_cache_hits_total[5m]) + rate(url_shortener_cache_misses_total[5m]))",
        "legendFormat": "Hit Rate"
      }],
      "datasource": "Prometheus",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "minVizValue": 0, "maxVizValue": 1}
    },
    {
      "id": 4,
      "title": "HTTP Request Latency (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(url_shortener_http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p99 {{method}} {{path}}"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "url_shortener_active_connections", "legendFormat": "Active"}],
      "datasource": "Prometheus"
    }
  ],
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"}
}
